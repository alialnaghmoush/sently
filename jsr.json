{
  "name": "@sendx/sendx",
  "version": "0.1.1",
  "description": "Runtime-agnostic email library for Node.js, Bun, Deno, and Cloudflare Workers",
  "license": "MIT",
  "publish": {
    "exclude": [
      ".cursor/",
      ".github/",
      "scripts/",
      "tests/",
      "tools/",
      "dist/",
      "node_modules/",
      "PROGRESS.md",
      "CLAUDE.md",
      "build.ts",
      "biome.json",
      "bun.lock"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./adapters/node": "./src/adapters/node.ts",
    "./adapters/bun": "./src/adapters/bun.ts",
    "./adapters/deno": "./src/adapters/deno.ts",
    "./adapters/cf": "./src/adapters/cf.ts",
    "./transports/smtp": "./src/transports/smtp.ts",
    "./transports/resend": "./src/transports/resend.ts",
    "./transports/sendgrid": "./src/transports/sendgrid.ts",
    "./transports/postmark": "./src/transports/postmark.ts"
  }
}
